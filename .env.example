# Copy this file to ".env" and fill in your real key. Never commit .env.
OPENAI_API_KEY=sk-...

# Optional overrides
OPENAI_MODEL=gpt-4o-mini
# If using an OpenAI-compatible provider (e.g. OpenRouter), set a base URL:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional, free. Literature search works without it at a lower rate limit.
# Get one at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
